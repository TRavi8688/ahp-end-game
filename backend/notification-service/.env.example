# notification-service/.env
# THIS FILE MUST NEVER BE COMMITTED TO GIT

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://notification_user:REPLACE_NOTIFICATION_DB_PASSWORD@localhost:5432/hospyn_notifications

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:REPLACE_NEW_REDIS_PASSWORD@localhost:6379/2

# ── JWT — same as auth-service SECRET_KEY ─────────────────────────────────────
SECRET_KEY=REPLACE_ME_SAME_AS_AUTH_SERVICE_JWT_SECRET_KEY
ALGORITHM=HS256

# ── Internal service auth ─────────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=REPLACE_ME_SAME_ACROSS_ALL_SERVICES

# ── App ───────────────────────────────────────────────────────────────────────
ENV=production
PORT=8004

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# ── Feature flags ─────────────────────────────────────────────────────────────
# IMPORTANT: Change to false in production so real SMS messages are sent
SMS_TEST_MODE=false
