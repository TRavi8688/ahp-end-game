# =============================================================================
# HOSPYN 2.0 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit the .env file to git. Only .env.example is tracked.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=hospyn_user
POSTGRES_PASSWORD=           # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=              # Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"

# ─── JWT (SHARED between Auth Service and Healthcare Core) ────────
# CRITICAL: Both services MUST use the same key and algorithm.
JWT_SECRET_KEY=              # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256

# ─── MinIO (Object Storage) ──────────────────────────────────────
MINIO_ROOT_USER=hospyn_minio
MINIO_ROOT_PASSWORD=         # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ─── SMTP (Email Delivery — optional for local dev) ──────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@hospyn.com

# ─── Twilio (SMS — optional for local dev) ────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
