# healthcare-core/.env
# THIS FILE MUST NEVER BE COMMITTED TO GIT

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://healthcare_user:REPLACE_HEALTHCARE_DB_PASSWORD@localhost:5432/hospyn_healthcare

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:REPLACE_NEW_REDIS_PASSWORD@localhost:6379/1

# ── JWT — MUST be identical to auth-service JWT_SECRET_KEY ───────────────────
JWT_SECRET_KEY=REPLACE_ME_SAME_AS_AUTH_SERVICE
JWT_ALGORITHM=HS256

# ── Partner JWT (separate key for partner app tokens) ─────────────────────────
PARTNER_JWT_SECRET=REPLACE_ME_GENERATE_SEPARATELY

# ── Internal service secret (same value across all services) ─────────────────
INTERNAL_SERVICE_SECRET=REPLACE_ME

# ── App ───────────────────────────────────────────────────────────────────────
ENV=production
ENVIRONMENT=production
ALLOWED_ORIGINS=https://app.hospyn.in,https://admin.hospyn.in,https://partner.hospyn.in

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── GCP Storage ───────────────────────────────────────────────────────────────
GCP_STORAGE_BUCKET=hospyn-medical-records

# ── Encryption key for PHI fields ────────────────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_ME
