# Force LF line endings for shell scripts (prevents Windows CRLF breaking bash in Docker)
*.sh text eol=lf

# Force LF for Python files
*.py text eol=lf

# Force LF for config files
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows batch files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
