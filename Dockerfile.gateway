FROM python:3.11-slim

WORKDIR /app

COPY start_api.py .
COPY backend /app/backend

# Install basic HTTPX and FastAPI needs for the gateway proxy
RUN pip install --no-cache-dir fastapi uvicorn httpx

ENV PORT=8000
ENV DOCKER_ENV=true
ENV AUTH_SERVICE_URL=http://auth-service:8001
ENV HEALTHCARE_SERVICE_URL=http://healthcare-core:8002

EXPOSE 8000

CMD ["uvicorn", "start_api:app", "--host", "0.0.0.0", "--port", "8000"]
