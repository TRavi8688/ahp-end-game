# =============================================================================
# Hospyn Environment Configuration
# Copy this to .env and fill all values before running.
# NEVER commit .env to git.
# =============================================================================

# --- Application ---
ENV=development
# ENV=production

# --- Security (REQUIRED — no defaults) ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_urlsafe_64

# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production: load from GCP Secret Manager, do NOT set this as an env var directly
FERNET_KEY=CHANGE_ME_generate_with_Fernet_generate_key

# --- Database (REQUIRED) ---
POSTGRES_USER=hospyn
# Use a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_DB=hospyn
DATABASE_URL=postgresql+asyncpg://hospyn:CHANGE_ME@localhost:5432/hospyn

# --- Redis (REQUIRED) ---
# Use a strong password: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# --- CORS (REQUIRED in production) ---
# Comma-separated list of allowed frontend origins.
# Example: https://app.hospyn.com,https://admin.hospyn.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- GCP (Production) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1

# --- Monitoring ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- SMS / Payments ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
