# ============================================================
# HOSPYN - .gitignore
# FIXES APPLIED:
#   - enc.key explicitly blocked (was not present before)
#   - *.key pattern added
#   - store_room/ added
#   - archive/ added
# ============================================================

# Python
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv
**/env/
**/venv/
**/ENV/
**/build/
**/dist/
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Environment files — NEVER commit real .env files
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.example

# ── SECRETS — NEVER COMMIT THESE ─────────────────────────────
# FIXED: enc.key was committed to the repo. This line prevents recurrence.
enc.key
*.key
*.pem
id_rsa
id_rsa.pub
key.json
fresh_deploy_key.json
secrets/
private/

# Node.js
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Logs
*.log
error_logs.txt

# Database files — never commit DB files
*.db
test.db
uploads/
secure_uploads/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Railway / GCP / Firebase
.railway
.railway/
.firebase/
.firebaserc
firebase.json

# Build artifacts
build/
dist/
*.egg-info/

# Temporary files
tmp/
temp/
*.tmp

# Dead code directories — FIXED: now explicitly excluded
# FIXED: archive/ added
archive/
# FIXED: store_room/ added
store_room/
scratch/
scratch_backup/
maintenance_archive/
backups/
our-jorny/
old-hospyn/
brain/
.gemini/
.agents/
.agent/

# Expo / React Native
**/.expo/
**/web-build/

# Alembic cache
alembic/__pycache__/

# Coverage reports
.coverage
coverage.xml
htmlcov/
