# ─────────────────────────────────────────────────────────────────────────────
# HOSPYN .gitignore
# PHASE 4 FIX: Added rules to block enc.key, *.db files, junk directories,
# and other sensitive/unnecessary files from being committed again.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.*
!.env.example
enc.key
*.key
*.pem
*.crt
*.p12
secrets/
*.secret

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Database files — NEVER commit SQLite DBs ─────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# ── Type checking / linting ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
# Root-level package-lock.json is orphaned (no root package.json)
/package-lock.json

# ── Build artifacts ───────────────────────────────────────────────────────────
/build/
/dist/
*.tsbuildinfo
.next/
out/

# ── Firebase ─────────────────────────────────────────────────────────────────
.firebase/
.firebaserc
# Keep firebase.json (deployment config) but block cache
firebase-debug.log

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Junk directories — should have been deleted, now also blocked ─────────────
/archive/
/backups/
/scratch/
/store_room/
/book/

