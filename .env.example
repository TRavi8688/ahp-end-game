# ============================================================
# HOSPYN - .env.example
# FIXES APPLIED:
#   - SECRET_KEY no longer has a dangerous default value
#   - REDIS_PASSWORD added (was missing entirely)
#   - POSTGRES_PASSWORD cannot be guessed
#   - SENTRY_DSN added
#   - ENC_KEY removed (must come from Secret Manager only)
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# In production, inject ALL these via GCP Secret Manager or
# your CI/CD secrets manager — never from a .env file.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=hospyn
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# FIXED: Redis now requires a password. This was missing before.
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_REDIS_PASSWORD
# The full Redis URL is constructed from password in docker-compose
# redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Security ──────────────────────────────────────────────────
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
# FIXED: Old default was "supersecretkey_please_change_in_production_12345"
# The app will now REFUSE TO START if this is set to the old default.
SECRET_KEY=REPLACE_WITH_128_CHARACTER_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Encryption Key ────────────────────────────────────────────
# CRITICAL: Do NOT put enc.key value here.
# The encryption key MUST be loaded from GCP Secret Manager at runtime.
# In app/core/config.py, load via: get_secret('HOSPYN_ENC_KEY')
# See docs/secret-manager-setup.md for instructions.

# ── Error Tracking ────────────────────────────────────────────
# Get from: https://sentry.io → New Project → FastAPI
# FIXED: This was entirely missing from the original .env.example
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=local

# ── External APIs ─────────────────────────────────────────────
# AI providers — also store in Secret Manager for production
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
GROQ_API_KEY=REPLACE_WITH_GROQ_KEY

# ── GCP (for production Secret Manager) ──────────────────────
GCP_PROJECT_ID=your-gcp-project-id
