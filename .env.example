# ─────────────────────────────────────────────────────────────────────────────
# Hospyn — Complete Environment Variables (Phases 3–14)
# Copy: cp .env.example .env   |   .env is gitignored — never commit it
# ─────────────────────────────────────────────────────────────────────────────

ENV=development

# ── CRITICAL secrets — rotate before ANY deployment ──────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet PHI key — replaces the compromised enc.key from the public repo
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# OTP HMAC secret (Phase 5 — separate from SECRET_KEY)
OTP_HMAC_SECRET=

# Audit log HMAC chain secret (Phase 13)
AUDIT_HMAC_SECRET=

# ── RS256 JWT keys (Phase 5) ──────────────────────────────────────────────────
# Generate: openssl genrsa -out private_key.pem 2048 && openssl rsa -in private_key.pem -pubout -out public_key.pem
# Paste PEM with \n newlines. Leave blank in dev (ephemeral key used).
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# ── Database (Phase 6/14) ──────────────────────────────────────────────────────
POSTGRES_USER=hospyn
POSTGRES_PASSWORD=
POSTGRES_DB=hospyn
DATABASE_URL=postgresql+asyncpg://hospyn:YOURPASSWORD@pgbouncer:5432/hospyn

# ── Redis (Phase 7 — authenticated) ───────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:YOURPASSWORD@redis:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Mandatory in production. Comma-separated domains.
ALLOWED_ORIGINS=

# ── Service URLs ───────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
HEALTHCARE_SERVICE_URL=http://healthcare-core:8002
AI_SERVICE_URL=http://ai-service:8003
UVICORN_WORKERS=4

# ── AI/LLM (Phase 10) — NO PHI until BAAs signed ──────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Observability (Phase 12) ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
PAGERDUTY_P0_KEY=
PAGERDUTY_P1_KEY=
PAGERDUTY_P2_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.googleapis.com:443

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=asia-south1
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Admin seeding only ────────────────────────────────────────────────────────
ADMIN_EMAIL=superadmin@hospyn.com
ADMIN_PASSWORD=
