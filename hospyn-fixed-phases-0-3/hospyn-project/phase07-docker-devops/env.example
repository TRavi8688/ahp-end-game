# .env.example — PHASE 07 + 08 FIXES
# Copy this file to .env and fill in all values before running docker-compose.
# NEVER commit .env to git. enc.key must NOT exist in the repo at all.

# ─── DATABASE ─────────────────────────────────────────────────────
# FIX: PostgreSQL replaces SQLite. All values required.
POSTGRES_USER=hospyn
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here_min_32_chars
POSTGRES_DB=hospyn

# ─── REDIS ────────────────────────────────────────────────────────
# FIX: Redis now requires authentication. Set a strong password.
REDIS_PASSWORD=CHANGE_ME_redis_password_min_32_chars

# ─── APP SECURITY ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64

# IMPORTANT: enc.key must NEVER be in this file or the repository.
# In production, load from GCP Secret Manager:
#   gcloud secrets versions access latest --secret="hospyn-enc-key"
# For local development only: create enc.key separately and reference via Docker secret.

# ─── CORS ─────────────────────────────────────────────────────────
# FIX: Replace "*" with your actual frontend domain(s).
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=https://app.hospyn.com,https://admin.hospyn.com

# ─── SERVICES ─────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
HEALTHCARE_SERVICE_URL=http://healthcare-core:8002

# ─── ENVIRONMENT ──────────────────────────────────────────────────
ENVIRONMENT=development
# Set to "production" in prod deployments

# ─── SENTRY (optional but recommended) ───────────────────────────
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ─── GCP (production only) ────────────────────────────────────────
# GCP_PROJECT_ID=hospyn-prod
# GCP_REGION=asia-south1
# BACKUP_BUCKET=hospyn-backups-prod
