# patient-app/.env
# ── Copy this and fill in real values. NEVER commit .env to git ──────────────

# ── API URLs ─────────────────────────────────────────────────────────────────
# In production, both auth and healthcare are proxied through one domain.
# In local dev, auth=8001, healthcare=8002.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# If auth-service and healthcare-core are on different ports locally:
# EXPO_PUBLIC_AUTH_URL=http://localhost:8001
# EXPO_PUBLIC_HEALTHCARE_URL=http://localhost:8002

# ── WebSocket ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_WS_URL=ws://localhost:8000

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID for type: "Web application"
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_oauth_client_id_here

# ── Sentry ────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=

# ── Environment ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_APP_ENV=development

# ── Production override (.env.production) ─────────────────────────────────────
# EXPO_PUBLIC_API_BASE_URL=https://api.hospyn.in
# EXPO_PUBLIC_WS_URL=wss://api.hospyn.in
# EXPO_PUBLIC_ENV=production
