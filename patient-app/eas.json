{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "entitlements": {
          "aps-environment": "development"
        }
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://hospyn-gateway-staging.web.app/api/v1",
        "EXPO_PUBLIC_ENVIRONMENT": "staging"
      }
    },
    "production": {
      "channel": "production",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "entitlements": {
          "aps-environment": "production"
        }
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://hospyn-gateway.web.app/api/v1",
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "hospyn-admin@hospyn.com",
        "ascAppId": "1649069643",
        "appleTeamId": "HOSPYN8688"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "closed"
      }
    }
  }
}
