# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control — it may contain secrets.

# Backend API gateway URL
VITE_API_BASE_URL=http://localhost:8000

# Environment tag (development | staging | production)
VITE_APP_ENV=development

# Sentry DSN — leave blank to disable error reporting
# VITE_SENTRY_DSN=
