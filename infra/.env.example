# backend/infra/.env
# THIS IS THE MASTER ENV FILE FOR DOCKER COMPOSE
# NEVER COMMIT THE REAL VERSION TO GIT — only commit .env.example
# Add infra/.env to your .gitignore
#
# ── HOW TO GENERATE SECRETS ──────────────────────────────────────────────────
# Strong password:  openssl rand -base64 32
# JWT secret:       python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Fernet key:       python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Postgres admin ────────────────────────────────────────────────────────────
DB_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Per-service DB passwords ──────────────────────────────────────────────────
AUTH_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
HEALTHCARE_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
NOTIFICATION_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AI_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
# !! ROTATE IMMEDIATELY — previous password was committed to git !!
# Steps: 1) Generate new password  2) Update Redis  3) Set below
REDIS_PASSWORD=ORSejoznwH7DK9Pi1PjZY8kxC-yKOL4H_AAtHyBQafs

# ── JWT — shared across all services (MUST be identical) ─────────────────────
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_SECRET

# ── Partner JWT (healthcare-core only) ───────────────────────────────────────
PARTNER_JWT_SECRET=REPLACE_WITH_SEPARATE_SECRET

# ── Internal service-to-service auth ─────────────────────────────────────────
INTERNAL_SERVICE_SECRET=REPLACE_WITH_32_CHAR_SECRET

# ── Encryption (Fernet for PHI fields) ───────────────────────────────────────
FERNET_KEY=REPLACE_WITH_FERNET_KEY

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
ALLOWED_ORIGINS=https://app.hospyn.in,https://admin.hospyn.in,https://partner.hospyn.in

# ── Sentry error monitoring ───────────────────────────────────────────────────
SENTRY_DSN=https://xxxxxx@sentry.io/xxxxxx

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+91xxxxxxxxxx

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_STORAGE_BUCKET=hospyn-medical-records

# ── AI Service ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
